# ═══════════════════════════════════════════════════════════════
# eYKON.ai — Environment variables
# Copy to apps/web/.env.local and fill in your values.
# ═══════════════════════════════════════════════════════════════

# ── Anthropic (required) ───────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-…

# ── Supabase (required) ────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi…
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi…
# For db:migrate / db:seed (one of these)
POSTGRES_URL=postgres://postgres:PASSWORD@db.xxxxxxx.supabase.co:5432/postgres
# SUPABASE_DB_URL=postgres://…

# ── Live-data providers ────────────────────────────────────────
AISHUB_API_KEY=                # AIS Hub username
# ACLED is paid — the platform falls back to GDELT.
# ACLED_EMAIL=
# ACLED_API_KEY=
ENTSOE_API_KEY=

# ── Intelligence Center ────────────────────────────────────────
# CRON_SECRET  — required. Bearer token Railway's scheduled triggers
#                use to call /api/cron/*. Generate a 32+ char random
#                string (e.g. `openssl rand -hex 32`).
CRON_SECRET=

# NEXT_PUBLIC_APP_URL — absolute URL of the web service. Used by the
# tool-executor for server-to-server fetches. Railway sets this at
# runtime; export a dev URL locally if you need chat tool-use to work
# against your dev server.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# NEXT_PUBLIC_DEMO_MODE — leave unset/false in production. When true
# the Intelligence Center eagerly falls back to seeded fixtures even
# if live data would be available (useful for screenshots / demos).
# NEXT_PUBLIC_DEMO_MODE=false

# FINANCE_PROVIDER — 'stub' (default) | 'bloomberg' | 'refinitiv'.
# Only 'stub' is implemented in v1 — the Commodities workspace renders
# from seeded price series until a provider is subscribed.
FINANCE_PROVIDER=stub

# CONFLICT_PROVIDER — 'supabase' (default — reads GDELT-ingested rows)
# | 'acled' (requires paid ACLED licence, disabled by default).
CONFLICT_PROVIDER=supabase

# ── Route group + auth progressive gating ──────────────────────
# NEXT_PUBLIC_AUTH_ENABLED — controls whether the (app) route group
# enforces a Supabase session. Set to 'false' during Phase 1 so the
# route restructure can ship without a signup surface; flip to 'true'
# in Phase 2 once Supabase Auth pages and user_profiles extensions
# are live.
NEXT_PUBLIC_AUTH_ENABLED=false

# ── Legal pages — Termly embedded widgets (Phase 3) ────────────
# One policy UUID per page. Each policy is drafted in the Termly
# dashboard and assigned a UUID by Termly; copy the UUID from the
# "Embed" tab of the policy into the matching env var. Until
# configured, the legal pages render a placeholder instead of the
# widget (so the build stays green during drafting). /terms and
# /privacy must be live and have their URLs pasted into the Lemon
# Squeezy store config AND the NOWPayments merchant dashboard
# BEFORE either payment integration can go live.
NEXT_PUBLIC_TERMLY_TERMS_UUID=
NEXT_PUBLIC_TERMLY_PRIVACY_UUID=
NEXT_PUBLIC_TERMLY_COOKIES_UUID=
NEXT_PUBLIC_TERMLY_DPA_UUID=
NEXT_PUBLIC_TERMLY_REFUND_UUID=

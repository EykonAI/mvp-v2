# eYKON ADS-B ingest worker — required env vars

# Supabase service-role client (same values as services/ais-ingest)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional tuning (defaults shown)
# POLL_INTERVAL_MS=60000     # full cycle cadence across all points
# REQUEST_SPACING_MS=1000    # gap between per-point adsb.lol requests (~1 req/s)
# ADSB_PROVIDER=adsb_lol     # informational; this worker targets adsb.lol
